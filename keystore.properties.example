# Copy this file to `keystore.properties` and fill in your own signing identity.
# For release hygiene, prefer storing the real copy outside this repository and
# pointing Gradle at it:
#
#   FREENOTE_KEYSTORE_PROPERTIES=/path/to/keystore.properties ./gradlew assembleRelease
#   ./gradlew -PfreenoteKeystoreProperties=/path/to/keystore.properties assembleRelease
#
#   cp keystore.properties.example keystore.properties
#
# Then generate a keystore (one-off):
#   keytool -genkeypair -v -keystore my.keystore -alias my \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# `storeFile` is resolved relative to this properties file, or may be absolute.
# keystore.properties and the *.keystore file are git-ignored - keep them private.
#
# Without this file the build still works:
#   - debug builds fall back to the default Android debug keystore
#   - release builds are produced UNSIGNED (sign them yourself with apksigner)

storeFile=my.keystore
storePassword=changeit
keyAlias=my
keyPassword=changeit
