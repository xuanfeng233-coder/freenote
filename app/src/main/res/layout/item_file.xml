<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Ncm.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: cover + badge + filename + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/coverThumb"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/cd_cover"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_cover"
                android:visibility="gone"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Ncm.MiniCover"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/formatBadge"
                style="@style/Widget.Ncm.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="NCM" />

            <TextView
                android:id="@+id/fileNameTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface"
                tools:text="song_name.ncm" />

            <!-- Status icon (success / failure) -->
            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                tools:src="@drawable/ic_check_circle"
                tools:tint="?attr/colorPrimary"
                tools:visibility="visible" />

            <!-- Progress (while decrypting) -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/itemProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="?attr/colorPrimary"
                app:indicatorSize="22dp"
                app:trackThickness="2.5dp" />
        </LinearLayout>

        <!-- Row 1b: failure reason (visible only on failure) -->
        <TextView
            android:id="@+id/detailTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            tools:text="此文件的解密密钥未嵌入文件中…"
            tools:visibility="visible" />

        <!-- Row 2: actions (visible only on success) -->
        <LinearLayout
            android:id="@+id/actionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/playButton"
                style="@style/Widget.Ncm.Button.TonalCompact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/play"
                app:icon="@drawable/ic_play" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editTagsButton"
                style="@style/Widget.Ncm.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/edit_tags"
                app:icon="@drawable/ic_edit" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareButton"
                style="@style/Widget.Ncm.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/share"
                app:icon="@drawable/ic_share" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
