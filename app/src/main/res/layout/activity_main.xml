<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".MainActivity">

    <!-- ============================ Main content ============================ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/app_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintEnd_toStartOf="@id/infoButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleTextView" />

        <ImageButton
            android:id="@+id/infoButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_help"
            android:src="@drawable/ic_info"
            app:layout_constraintBottom_toBottomOf="@id/importKeysButton"
            app:layout_constraintEnd_toStartOf="@id/importKeysButton"
            app:layout_constraintTop_toTopOf="@id/importKeysButton"
            app:tint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/importKeysButton"
            style="@style/Widget.Ncm.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/import_keys"
            app:icon="@drawable/ic_folder"
            app:layout_constraintBottom_toBottomOf="@id/subtitleTextView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/titleTextView" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/outputDirButton"
            style="@style/Widget.Ncm.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/output_dir_default"
            app:icon="@drawable/ic_folder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/importKeysButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rootImportButton"
            style="@style/Widget.Ncm.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/root_import"
            android:visibility="gone"
            app:icon="@drawable/ic_folder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/outputDirButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectFilesButton"
            style="@style/Widget.Ncm.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/select_files"
            app:icon="@drawable/ic_folder"
            app:layout_constraintEnd_toStartOf="@id/actionDivider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rootImportButton" />

        <View
            android:id="@+id/actionDivider"
            android:layout_width="12dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@id/selectFilesButton"
            app:layout_constraintEnd_toStartOf="@id/decryptAllButton"
            app:layout_constraintStart_toEndOf="@id/selectFilesButton"
            app:layout_constraintTop_toTopOf="@id/selectFilesButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/decryptAllButton"
            style="@style/Widget.Ncm.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="@string/decrypt_all"
            app:icon="@drawable/ic_lock_open"
            app:layout_constraintBottom_toBottomOf="@id/selectFilesButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/actionDivider"
            app:layout_constraintTop_toTopOf="@id/selectFilesButton" />

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_idle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/selectFilesButton" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:indicatorColor="?attr/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusTextView"
            app:trackColor="?attr/colorSurfaceContainerHighest"
            app:trackCornerRadius="2dp"
            tools:visibility="visible" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressBar" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fileRecyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="96dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            tools:itemCount="3"
            tools:listitem="@layout/item_file" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@string/cd_empty_icon"
                android:src="@drawable/ic_music_note"
                app:tint="?attr/colorOutline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/empty_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/empty_hint"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOutline" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrim that dims the list as the player expands -->
    <View
        android:id="@+id/playerScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@color/md_scrim"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <!-- ============================ Player bottom sheet ============================ -->
    <FrameLayout
        android:id="@+id/playerSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/player_sheet_bg"
        android:visibility="invisible"
        app:behavior_hideable="true"
        app:behavior_peekHeight="76dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        tools:visibility="visible">

        <!-- Ambient album-art gradient (shown only when expanded) -->
        <View
            android:id="@+id/ambientBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0" />

        <!-- ===================== Full player (fades in on expand) ===================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/fullPlayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <View
                android:id="@+id/dragHandle"
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:alpha="0.5"
                android:background="@drawable/drag_handle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/collapseButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_collapse"
                android:src="@drawable/ic_expand_more"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dragHandle"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/nowPlayingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/now_playing"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintBottom_toBottomOf="@id/collapseButton"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/collapseButton" />

            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/edit_metadata"
                android:src="@drawable/ic_edit"
                app:layout_constraintBottom_toBottomOf="@id/collapseButton"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/collapseButton"
                app:tint="?attr/colorOnSurfaceVariant" />

            <!-- Cover container: slide-driven scale/translate (the "container expand" feel) -->
            <FrameLayout
                android:id="@+id/coverContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintBottom_toTopOf="@id/fullTitle"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/collapseButton"
                app:layout_constraintVertical_bias="0.5"
                app:layout_constraintWidth_max="380dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/fullCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_cover"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_cover"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Ncm.Cover" />
            </FrameLayout>

            <TextView
                android:id="@+id/fullTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:fadingEdge="horizontal"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/fullArtist"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="歌曲标题" />

            <TextView
                android:id="@+id/fullArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fullTitle"
                tools:text="艺术家 — 专辑" />

            <com.google.android.material.slider.Slider
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:stepSize="0"
                android:valueFrom="0"
                android:valueTo="1"
                app:labelBehavior="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fullArtist"
                app:thumbColor="?attr/colorPrimary"
                app:trackColorActive="?attr/colorPrimary"
                app:trackColorInactive="?attr/colorSurfaceContainerHighest" />

            <TextView
                android:id="@+id/positionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_zero"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="@id/seekBar"
                app:layout_constraintTop_toBottomOf="@id/seekBar" />

            <TextView
                android:id="@+id/durationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_zero"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintEnd_toEndOf="@id/seekBar"
                app:layout_constraintTop_toBottomOf="@id/seekBar" />

            <!-- Transport controls -->
            <ImageButton
                android:id="@+id/shuffleButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_shuffle"
                android:src="@drawable/ic_shuffle"
                app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
                app:layout_constraintEnd_toStartOf="@id/prevButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/fullPlayPause"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/prevButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_previous"
                android:src="@drawable/ic_skip_previous"
                app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
                app:layout_constraintEnd_toStartOf="@id/fullPlayPause"
                app:layout_constraintStart_toEndOf="@id/shuffleButton"
                app:layout_constraintTop_toTopOf="@id/fullPlayPause"
                app:tint="?attr/colorOnSurface" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fullPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:contentDescription="@string/cd_play_pause"
                android:src="@drawable/ic_play"
                app:backgroundTint="?attr/colorPrimary"
                app:fabCustomSize="72dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/positionText"
                app:maxImageSize="36dp"
                app:tint="?attr/colorOnPrimary" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_next"
                android:src="@drawable/ic_skip_next"
                app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
                app:layout_constraintEnd_toStartOf="@id/repeatButton"
                app:layout_constraintStart_toEndOf="@id/fullPlayPause"
                app:layout_constraintTop_toTopOf="@id/fullPlayPause"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/repeatButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_repeat"
                android:src="@drawable/ic_repeat"
                app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/nextButton"
                app:layout_constraintTop_toTopOf="@id/fullPlayPause"
                app:tint="?attr/colorOnSurfaceVariant" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ===================== Mini bar (collapsed peek) ===================== -->
        <LinearLayout
            android:id="@+id/miniBar"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/miniCover"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/cd_cover"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_cover"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Ncm.MiniCover" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/miniTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:scrollHorizontally="true"
                    android:singleLine="true"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    tools:text="歌曲标题" />

                <TextView
                    android:id="@+id/miniArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="艺术家" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/miniPlayPause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_play_pause"
                android:src="@drawable/ic_play"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/miniNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_next"
                android:src="@drawable/ic_skip_next"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Thin progress line pinned to the very top of the mini bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/miniProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            app:indicatorColor="?attr/colorPrimary"
            app:trackColor="@android:color/transparent"
            app:trackThickness="2dp" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
