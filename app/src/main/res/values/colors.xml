<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Material 3 dark color scheme for 音频解锁.
      Brand identity: teal accent on a deep navy surface family.
      These map 1:1 onto the M3 color roles wired up in themes.xml — never
      hardcode a hex value in a layout; reference ?attr/color* or these names.
    -->

    <!-- Primary (teal accent) -->
    <color name="md_primary">#80CBC4</color>
    <color name="md_on_primary">#003733</color>
    <color name="md_primary_container">#005048</color>
    <color name="md_on_primary_container">#9FF2E9</color>

    <!-- Secondary (muted lavender, complements the navy) -->
    <color name="md_secondary">#B7C4E8</color>
    <color name="md_on_secondary">#212E4B</color>
    <color name="md_secondary_container">#374465</color>
    <color name="md_on_secondary_container">#D9E2FF</color>

    <!-- Tertiary (soft violet for badges / highlights) -->
    <color name="md_tertiary">#D6BEE4</color>
    <color name="md_on_tertiary">#3A2948</color>
    <color name="md_tertiary_container">#523F60</color>
    <color name="md_on_tertiary_container">#F2DAFF</color>

    <!-- Error -->
    <color name="md_error">#FFB4AB</color>
    <color name="md_on_error">#690005</color>
    <color name="md_error_container">#93000A</color>
    <color name="md_on_error_container">#FFDAD6</color>

    <!-- Background & surface (deep navy family) -->
    <color name="md_background">#13132A</color>
    <color name="md_on_background">#E4E1E9</color>
    <color name="md_surface">#13132A</color>
    <color name="md_on_surface">#E4E1E9</color>
    <color name="md_surface_variant">#45465A</color>
    <color name="md_on_surface_variant">#A9A8BC</color>
    <color name="md_outline">#5B5B72</color>
    <color name="md_outline_variant">#2C2C48</color>

    <!-- Tonal surface containers (elevation tiers) -->
    <color name="md_surface_container_lowest">#0E0E22</color>
    <color name="md_surface_container_low">#1A1A30</color>
    <color name="md_surface_container">#1E1E38</color>
    <color name="md_surface_container_high">#262644</color>
    <color name="md_surface_container_highest">#2F2F50</color>

    <!-- Scrim -->
    <color name="md_scrim">#000000</color>

    <!-- Adaptive launcher icon background (matches the teal in ic_launcher.png) -->
    <color name="ic_launcher_background">#179A95</color>
</resources>
