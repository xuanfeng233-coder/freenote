    <!-- Help / key-source note -->
    <string name="help">说明</string>
    <string name="cd_help">使用说明</string>
    <string name="help_title">QQ音乐 / 酷狗音乐 密钥说明</string>
    <string name="help_message">部分新版客户端不把解密密钥写进文件，密钥保存在 App 私有数据库里。这类文件需要 root 导出密钥（用「导入密钥」），或者改用旧版客户端下载——旧版会把密钥内嵌进文件，可直接离线解密：\n\n• QQ音乐（尾部 STag / musicex，约客户端 ≥11.6）\n  └ 旧版安装包 10.12.0.8（v11.6 前内嵌密钥）\n\n• 酷狗音乐（.kgg，约安卓 ≥20.x）\n  └ 回退到安卓 12.5.6（最后支持 .kgm 的版本，2024-11）\n\n网易云(.ncm)、QQ音乐内嵌密钥(QTag/数字尾部)、酷狗 .kgm/.vpr、酷我 .kwm 均可直接离线解密，无需密钥导入。</string>
    <string name="help_got_it">知道了</string>

